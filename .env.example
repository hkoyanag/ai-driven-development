# ==========================================
# AI-Driven Development Configuration Template (v1.5.0 Multi-AI)
# ==========================================

# 環境ステージ設定 (Dev / QA / Prod)
ENV_STAGE=Dev

# Redmine 接続情報
REDMINE_URL=http://localhost:3000
REDMINE_ADMIN_USER=admin
REDMINE_ADMIN_PASSWORD=password
REDMINE_PROJECT_ID=ai-test

# Redmine チケット作成時のデフォルト各種ID
REDMINE_DEFAULT_TRACKER_ID=1
REDMINE_DEFAULT_STATUS_ID=1
REDMINE_DEFAULT_PRIORITY_ID=2

# AI運行・制御モード設定
AI_EXEC_MODE=Auto
AI_CHECK_INTERVAL=12
AI_RATE_LIMIT_SLEEP=12

# ==========================================
# AI Provider Configuration
# ==========================================
# 利用するAIプロバイダを指定 (OpenAI / Anthropic / Gemini / Groq / OpenRouter)
ACTIVE_AI_PROVIDER=Groq

# 各社APIキーの設定
# ⚠️ 注意: 本物のAPIキーはここには絶対に記入せず、ローカルの .env にのみ記述してください。
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE

# 各プロバイダのデフォルト使用モデル
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-latest
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.3-70b-specdec
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct:free